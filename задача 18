   - Android: Камера → Настройки → Сохранять местоположение → Выключить

3. Используйте программы для анонимизации:
   - MAT2 (Metadata Anonymisation Toolkit)
   - ExifTool
   - ImageOptim (macOS)

4. Перед отправкой проверяйте файлы на наличие метаданных
        """)
    
    def generate_json_report(self, output_file: str = 'metadata_report.json'):
        """Генерирует JSON-отчёт о метаданных"""
        report = {
            'metadata': self.metadata,
            'privacy_risks': self.privacy_risks,
            'analysis_date': datetime.now().isoformat()
        }
        
        # Убираем бинарные данные для JSON
        if 'exif_data' in report['metadata']:
            # Конвертируем все значения в строки
            report['metadata']['exif_data'] = {k: str(v) for k, v in report['metadata']['exif_data'].items()}
        
        with open(output_file, 'w', encoding='utf-8') as f:
            json.dump(report, f, indent=2, ensure_ascii=False, default=str)
        
        print(f"\n💾 JSON-отчёт сохранён в: {output_file}")

def create_sample_image_with_metadata():
    """Создаёт тестовое изображение с метаданными (если PIL установлен)"""
    if not PIL_AVAILABLE:
        return None
    
    print("\n🎨 Создание тестового изображения с метаданными...")
    
    try:
        from PIL import Image
        from PIL import ImageDraw
        
        # Создаём изображение
        img = Image.new('RGB', (800, 600), color='white')
        draw = ImageDraw.Draw(img)
        
        # Рисуем что-нибудь
        draw.rectangle([100, 100, 700, 500], outline='black', width=2)
        draw.text((300, 250), "Test Image for Metadata Analysis", fill='black')
        
        # Сохраняем с метаданными
        output_path = 'test_with_metadata.jpg'
        
        # Сохраняем с базовыми метаданными
        img.save(output_path, quality=95)
        
        print(f"✓ Создано тестовое изображение: {output_path}")
        print("  (для полноценного теста используйте реальное фото с GPS данными)")
        
        return output_path
        
    except Exception as e:
        print(f"⚠️ Не удалось создать тестовое изображение: {e}")
        return None

def check_requirements():
    """Проверяет наличие необходимых библиотек"""
    missing = []
    
    if not EXIFREAD_AVAILABLE:
        missing.append("exifread")
    if not PIL_AVAILABLE:
        missing.append("Pillow")
    
    if missing:
        print("\n⚠️ Отсутствуют необходимые библиотеки:")
        print(f"   {', '.join(missing)}")
        print("\nУстановите их командой:")
        print(f"   pip install {' '.join(missing)}")
        print("\nИли установите все зависимости:")
        print("   pip install exifread Pillow")
        return False
    
    return True

def main():
