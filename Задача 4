4. Шифр гаммирования
Реализовать шифрование/дешифрование текста методом XOR с ключом
(гаммой). Продемонстрировать работу на примере фразы "Прикладная
информатика" в UTF-8.

def gamma_cipher(text, key, mode='encrypt'):
    """
    Шифрование/дешифрование методом XOR с гаммой.
    
    Args:
        text: исходный текст (для шифрования) или зашифрованные байты (для дешифрования)
        key: ключ (строка или байты)
        mode: 'encrypt' или 'decrypt'
    
    Returns:
        str или bytes: результат шифрования/дешифрования
    """
    # Преобразуем текст в байты UTF-8
    if mode == 'encrypt':
        text_bytes = text.encode('utf-8')
    else:
        text_bytes = text if isinstance(text, bytes) else text.encode('utf-8')
    
    # Преобразуем ключ в байты (если строка)
    if isinstance(key, str):
        key_bytes = key.encode('utf-8')
    else:
        key_bytes = key
    
    # Повторяем ключ, чтобы он соответствовал длине текста
    key_repeated = (key_bytes * (len(text_bytes) // len(key_bytes) + 1))[:len(text_bytes)]
    
    # XOR шифрование
    result_bytes = bytes(a ^ b for a, b in zip(text_bytes, key_repeated))
    
    if mode == 'encrypt':
        return result_bytes  # Возвращаем байты для шифротекста
    else:
        return result_bytes.decode('utf-8')  # Возвращаем строку для дешифрованного текста

def bytes_to_hex(data):
    """Преобразует байты в hex-строку для отображения"""
    return ' '.join(f'{b:02x}' for b in data)

def bytes_to_binary(data):
    """Преобразует байты в двоичную строку для отображения"""
    return ' '.join(f'{b:08b}' for b in data)

def demonstrate_gamma_cipher():
    """Демонстрация работы шифра гаммирования"""
    
    print("=" * 80)
    print("ШИФР ГАММИРОВАНИЯ (XOR)")
    print("=" * 80)
    
    # Исходные данные
    original_text = "Прикладная информатика"
    key = "КЛЮЧ"  # Ключ для гаммирования
    
    print("\n1. Исходные данные:")
    print(f"   Текст: {original_text}")
    print(f"   Ключ: {key}")
    print(f"   Длина текста: {len(original_text)} символов")
    print(f"   Длина ключа: {len(key)} символов")
    
    # Показываем UTF-8 представление
    text_utf8 = original_text.encode('utf-8')
    print(f"\n2. UTF-8 представление текста:")
    print(f"   Байты (hex): {bytes_to_hex(text_utf8)}")
    print(f"   Байты (bin): {bytes_to_binary(text_utf8)}")
    
    # Шифрование
    print("\n" + "=" * 80)
    print("3. ШИФРОВАНИЕ")
    print("=" * 80)
    
    encrypted = gamma_cipher(original_text, key, mode='encrypt')
    print(f"\n   Зашифрованные данные (байты):")
    print(f"   Hex: {bytes_to_hex(encrypted)}")
    print(f"   Bin: {bytes_to_binary(encrypted)}")
    
    # Пробуем интерпретировать как текст (получится "мусор")
    try:
        encrypted_as_text = encrypted.decode('utf-8', errors='replace')
        print(f"\n   Попытка прочитать как текст: {encrypted_as_text}")
    except:
        pass
    
    # Дешифрование
    print("\n" + "=" * 80)
    print("4. ДЕШИФРОВАНИЕ")
    print("=" * 80)
    
    decrypted = gamma_cipher(encrypted, key, mode='decrypt')
    print(f"\n   Дешифрованный текст: {decrypted}")
    
    # Проверка
    print("\n" + "=" * 80)
    print("5. ПРОВЕРКА")
    print("=" * 80)
    
    if decrypted == original_text:
        print("\n   ✓ УСПЕХ! Текст успешно зашифрован и дешифрован")
    else:
        print("\n   ✗ ОШИБКА! Текст не совпадает")
    
    print(f"\n   Исходный текст:    {original_text}")
    print(f"   Дешифрованный:     {decrypted}")
    
    return encrypted, original_text, key

