class GammaCipher:
    """Класс для работы с шифром гаммирования"""
    
    def __init__(self, key):
        """
        Инициализация шифра с заданным ключом.
        
        Args:
            key: ключ для шифрования
        """
        self.key = key
        if isinstance(key, str):
            self.key_bytes = key.encode('utf-8')
        else:
            self.key_bytes = key
    
    def encrypt(self, text):
        """Шифрование текста"""
        return gamma_cipher(text, self.key_bytes, mode='encrypt')
    
    def decrypt(self, ciphertext):
        """Дешифрование текста"""
        return gamma_cipher(ciphertext, self.key_bytes, mode='decrypt')
    
    def process_file(self, input_file, output_file, mode='encrypt'):
        """
        Шифрование/дешифрование файла.
        
        Args:
            input_file: путь к входному файлу
            output_file: путь к выходному файлу
            mode: 'encrypt' или 'decrypt'
        """
        with open(input_file, 'rb') as f:
            data = f.read()
        
        # XOR с повторяющимся ключом
        key_repeated = (self.key_bytes * (len(data) // len(self.key_bytes) + 1))[:len(data)]
        result = bytes(a ^ b for a, b in zip(data, key_repeated))
        
        with open(output_file, 'wb') as f:
            f.write(result)
        
        print(f"Файл {input_file} -> {output_file} ({mode}ed)")

