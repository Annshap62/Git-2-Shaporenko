def demonstrate_limitations():
    """Демонстрация ограничений метода"""
    print("\n" + "=" * 80)
    print("⚠️ ОГРАНИЧЕНИЯ И ОСОБЕННОСТИ")
    print("=" * 80)
    
    p = 17
    cipher = HomomorphicEncryptionDemo(p=p)
    
    print(f"""
1. Область определения:
   - Числа должны быть в диапазоне [0, {p-1}]
   - Работает только по модулю {p}
   
2. Гомоморфные свойства:
   ✅ Мультипликативное: E(a) * E(b) = E(a * b mod p)
   ❌ Аддитивное: E(a) + E(b) ≠ E(a + b mod p)
   
3. Безопасность:
   - Данная схема небезопасна для реального использования
   - Используется только для демонстрации концепции
   - Легко взламывается при известной паре (x, E(x))
   
4. Практические ограничения:
   - Ключ должен быть взаимно прост с p
   - При большом количестве операций накапливается ошибка округления
   - Требуется переодическая редукция по модулю
    """)
    
    # Демонстрация сложения (не работает)
    print("\n📌 Демонстрация: сложение НЕ гомоморфно")
    a, b = 3, 5
    enc_a = cipher.encrypt(a)
    enc_b = cipher.encrypt(b)
    
    sum_encrypted = (enc_a + enc_b) % p
    sum_direct = cipher.encrypt((a + b) % p)
    
    print(f"   E({a}) + E({b}) mod {p} = {enc_a} + {enc_b} = {sum_encrypted}")
    print(f"   E({a} + {b}) = E({(a+b)%p}) = {sum_direct}")
    print(f"   Равенство: {sum_encrypted == sum_direct} (не работает как гомоморфное сложение)")

