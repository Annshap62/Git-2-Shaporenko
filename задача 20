        print("🔢 ПРОИЗВЕДЕНИЕ НЕСКОЛЬКИХ ЧИСЕЛ")
        print("=" * 80)
        
        numbers = [2, 3, 5, 7, 11]
        product_original = 1
        for n in numbers:
            product_original = (product_original * n) % self.cipher.p
        
        # Шифруем все числа
        encrypted_numbers = self.cipher.encrypt_list(numbers)
        
        # Гомоморфно перемножаем
        encrypted_product = self.cipher.multiply_encrypted_list(encrypted_numbers)
        
        # Расшифровываем
        decrypted_product = self.cipher.decrypt(encrypted_product)
        
        print(f"\nИсходные числа: {numbers}")
        print(f"Произведение (mod p): {product_original}")
        print(f"\nЗашифрованные числа: {encrypted_numbers}")
        print(f"Гомоморфное произведение (зашифровано): {encrypted_product}")
        print(f"Расшифрованное произведение: {decrypted_product}")
        print(f"\n✅ Произведение зашифрованных чисел равно шифру произведения: {product_original == decrypted_product}")
    
    def demonstrate_with_different_keys(self):
        """Демонстрация с разными ключами"""
        print("\n" + "=" * 80)
        print("🔑 ДЕМОНСТРАЦИЯ С РАЗНЫМИ КЛЮЧАМИ")
        print("=" * 80)
        
        # Разные модули
        modules = [23, 31, 37, 41, 43, 47]
        
        print(f"\n{'Модуль p':<10} {'Ключ':<8} {'a':<4} {'b':<4} {'E(a)*E(b)':<12} {'E(a*b)':<12} {'Совпадение':<12}")
        print("-" * 70)
        
        a, b = 4, 5
        
        for p in modules:
            cipher = HomomorphicEncryptionDemo(p=p, key=None)  # Случайный ключ
            enc_a = cipher.encrypt(a % p)
