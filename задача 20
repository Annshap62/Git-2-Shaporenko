"""
20. Гомоморфное шифрование (демо с примитивом)
Реализовать простое умножение зашифрованных чисел: шифр = (число * ключ)
mod p. Показать, что произведение шифр-текстов = шифру произведения.

"""
import random
import math
from typing import Tuple, List
import matplotlib.pyplot as plt

class HomomorphicEncryptionDemo:
    """
    Простая схема гомоморфного шифрования на основе умножения по модулю.
    Шифр: E(x) = (x * key) mod p
    Свойство: E(x) * E(y) mod p = E(x * y) mod p
    """
    
    def __init__(self, p: int = None, key: int = None):
        """
        Инициализация схемы шифрования.
        
        Args:
            p: модуль (простое число)
            key: секретный ключ
        """
        # Генерируем большое простое число, если не задано
        if p is None:
            self.p = self._generate_prime(100, 1000)
        else:
            self.p = p
        
        # Генерируем ключ (обратимый элемент по модулю p)
        if key is None:
            self.key = self._generate_key()
        else:
            self.key = key % self.p
        
        # Вычисляем обратный ключ для дешифрования
        self.inv_key = self._mod_inverse(self.key, self.p)
        
        print(f"🔐 Система инициализирована:")
        print(f"   Модуль p = {self.p} (простое число)")
        print(f"   Секретный ключ = {self.key}")
        print(f"   Обратный ключ = {self.inv_key}")
        print(f"   Проверка: {self.key} * {self.inv_key} mod {self.p} = {(self.key * self.inv_key) % self.p}")
    
    def _is_prime(self, n: int) -> bool:
        """Проверка на простоту (упрощённая)"""
        if n < 2:
            return False
        for i in range(2, int(math.sqrt(n)) + 1):
            if n % i == 0:
                return False
        return True
    
    def _generate_prime(self, min_val: int, max_val: int) -> int:
        """Генерация простого числа в заданном диапазоне"""
        primes = [i for i in range(min_val, max_val) if self._is_prime(i)]
        return random.choice(primes)
    
    def _generate_key(self) -> int:
        """Генерация обратимого ключа (не должен делиться на p)"""
        while True:
            key = random.randint(2, self.p - 1)
            if math.gcd(key, self.p) == 1:
                return key
    
    def _mod_inverse(self, a: int, m: int) -> int:
        """Нахождение обратного элемента по модулю (расширенный алгоритм Евклида)"""
        # a * x ≡ 1 mod m
        g, x, y = self._extended_gcd(a, m)
        if g != 1:
            raise ValueError(f"Обратный элемент не существует: {a} mod {m}")
        return x % m
    
    def _extended_gcd(self, a: int, b: int) -> Tuple[int, int, int]:
        """Расширенный алгоритм Евклида"""
        if a == 0:
            return b, 0, 1
        gcd, x1, y1 = self._extended_gcd(b % a, a)
        x = y1 - (b // a) * x1
        y = x1
        return gcd, x, y
    
    def encrypt(self, plaintext: int) -> int:
        """
        Шифрование числа.
        E(x) = (x * key) mod p
        """
        if plaintext < 0 or plaintext >= self.p:
            raise ValueError(f"Число должно быть в диапазоне [0, {self.p-1}]")
        return (plaintext * self.key) % self.p
    
    def decrypt(self, ciphertext: int) -> int:
        """
        Дешифрование числа.
        D(c) = (c * inv_key) mod p
        """
        return (ciphertext * self.inv_key) % self.p
    
    def encrypt_list(self, numbers: List[int]) -> List[int]:
        """Шифрование списка чисел"""
        return [self.encrypt(n) for n in numbers]
    
    def decrypt_list(self, ciphertexts: List[int]) -> List[int]:
        """Дешифрование списка чисел"""
        return [self.decrypt(c) for c in ciphertexts]
    
    def multiply_encrypted(self, cipher1: int, cipher2: int) -> int:
        """
        Гомоморфное умножение зашифрованных чисел.
        E(x) * E(y) mod p = E(x * y) mod p
        """
        return (cipher1 * cipher2) % self.p
    
    def multiply_encrypted_list(self, ciphertexts: List[int]) -> int:
        """Гомоморфное умножение нескольких зашифрованных чисел"""
        result = 1
        for c in ciphertexts:
            result = (result * c) % self.p
        return result

class HomomorphicPropertyDemo:
    """Демонстрация свойств гомоморфного шифрования"""
    
    def __init__(self):
        self.cipher = None
    
    def demonstrate_multiplicative_property(self):
        """Демонстрация мультипликативного свойства"""
        print("\n" + "=" * 80)
        print("🔢 ДЕМОНСТРАЦИЯ МУЛЬТИПЛИКАТИВНОГО СВОЙСТВА")
        print("=" * 80)
        
        # Создаём экземпляр шифра
        self.cipher = HomomorphicEncryptionDemo(p=97)  # Используем простое число 97
        
        # Тестовые числа
        test_pairs = [
            (3, 5),
            (7, 11),
            (2, 15),
            (23, 45),
            (1, 42)
        ]
        
        print(f"\n📊 Проверка свойства: E(a * b) = E(a) * E(b) mod p")
        print(f"{'a':<6} {'b':<6} {'a*b mod p':<12} {'E(a)':<8} {'E(b)':<8} {'E(a)*E(b) mod p':<18} {'E(a*b)':<12} {'Результат':<10}")
        print("-" * 100)
        
        for a, b in test_pairs:
            a_mod = a % self.cipher.p
            b_mod = b % self.cipher.p
            product_original = (a_mod * b_mod) % self.cipher.p
            
            # Шифруем
            enc_a = self.cipher.encrypt(a_mod)
            enc_b = self.cipher.encrypt(b_mod)
            
            # Гомоморфное умножение
            enc_product_homo = self.cipher.multiply_encrypted(enc_a, enc_b)
            
            # Шифруем произведение напрямую
            enc_product_direct = self.cipher.encrypt(product_original)
            
            # Расшифровываем гомоморфное произведение
            decrypted_product = self.cipher.decrypt(enc_product_homo)
            
            # Проверка
            success = (enc_product_homo == enc_product_direct) and (decrypted_product == product_original)
            status = "✅" if success else "❌"
            
            print(f"{a:<6} {b:<6} {product_original:<12} {enc_a:<8} {enc_b:<8} {enc_product_homo:<18} {enc_product_direct:<12} {status:<10}")
    
    def demonstrate_product_of_multiple_numbers(self):
